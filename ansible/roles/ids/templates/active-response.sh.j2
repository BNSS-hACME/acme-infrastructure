#!/usr/bin/env bash
# Active Response Script – managed by Ansible (ids role)
# Monitors Suricata eve.json and blocks attacker IPs:
#   - WLAN attackers → on external AP via SSH
#   - VPN  attackers → locally on router via iptables FORWARD
set -euo pipefail

# ---- Configuration (from Ansible) ----
AP_HOST="{{ ids_ap_ssh_host }}"
AP_USER="{{ ids_ap_ssh_user }}"
AP_PORT="{{ ids_ap_ssh_port }}"
AP_KEY="{{ ids_ap_ssh_key }}"
BLOCK_DURATION="{{ ids_block_duration }}"
MIN_SEVERITY="{{ ids_min_alert_severity }}"
MAX_SEVERITY="{{ ids_max_alert_severity }}"
VPN_SUBNET="{{ ids_vpn_subnet }}"
DRY_RUN="{{ ids_active_response_dry_run | lower }}"
EVE_LOG="{{ ids_log_dir }}/{{ ids_eve_log }}"
LOG_FILE="/var/log/ids/active-response.log"
BLOCK_LIST="/var/lib/ids/blocked-ips.txt"
mkdir -p "$(dirname "$BLOCK_LIST")"
touch "$BLOCK_LIST"

# Whitelist (CIDR or single IPs)
WHITELIST=(
{% for ip in ids_whitelist_ips %}
  "{{ ip }}"
{% endfor %}
)

# ---- Functions ----

log_msg() {
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG_FILE"
}

is_whitelisted() {
  local ip="$1"
  for entry in "${WHITELIST[@]}"; do
    if echo "$ip" | grep -qP "^$(echo "$entry" | sed 's|/.*||')" 2>/dev/null; then
      # Simple prefix match for subnets
      local subnet_prefix
      subnet_prefix=$(echo "$entry" | cut -d'/' -f1 | cut -d'.' -f1-3)
      local ip_prefix
      ip_prefix=$(echo "$ip" | cut -d'.' -f1-3)
      if [[ "$subnet_prefix" == "$ip_prefix" || "$entry" == "$ip" ]]; then
        return 0
      fi
    fi
  done
  return 1
}

is_vpn_client() {
  local ip="$1"
  local vpn_prefix
  vpn_prefix=$(echo "$VPN_SUBNET" | cut -d'/' -f1 | cut -d'.' -f1-3)
  local ip_prefix
  ip_prefix=$(echo "$ip" | cut -d'.' -f1-3)
  [[ "$vpn_prefix" == "$ip_prefix" ]]
}

is_already_blocked() {
  local ip="$1"
  grep -q "^${ip}$" "$BLOCK_LIST" 2>/dev/null
}

block_on_ap() {
  local ip="$1"
  log_msg "BLOCK [AP] $ip on $AP_HOST"
  ssh -i "$AP_KEY" -p "$AP_PORT" \
      -o StrictHostKeyChecking=no \
      -o ConnectTimeout=5 \
      "${AP_USER}@${AP_HOST}" \
      "iptables -I FORWARD -s $ip -j DROP" 2>>"$LOG_FILE" || {
    log_msg "ERROR: Failed to block $ip on AP"
    return 1
  }
}

unblock_on_ap() {
  local ip="$1"
  log_msg "UNBLOCK [AP] $ip on $AP_HOST"
  ssh -i "$AP_KEY" -p "$AP_PORT" \
      -o StrictHostKeyChecking=no \
      -o ConnectTimeout=5 \
      "${AP_USER}@${AP_HOST}" \
      "iptables -D FORWARD -s $ip -j DROP" 2>>"$LOG_FILE" || true
}

block_on_router() {
  local ip="$1"
  log_msg "BLOCK [ROUTER] $ip locally (VPN client)"
  iptables -I FORWARD -s "$ip" -j DROP 2>>"$LOG_FILE" || {
    log_msg "ERROR: Failed to block $ip on router"
    return 1
  }
}

unblock_on_router() {
  local ip="$1"
  log_msg "UNBLOCK [ROUTER] $ip locally"
  iptables -D FORWARD -s "$ip" -j DROP 2>>"$LOG_FILE" || true
}

schedule_unblock() {
  local ip="$1"
  local location="$2"
  (
    sleep "$BLOCK_DURATION"
    if [[ "$location" == "ap" ]]; then
      unblock_on_ap "$ip"
    else
      unblock_on_router "$ip"
    fi
    sed -i "/^${ip}$/d" "$BLOCK_LIST"
    log_msg "Auto-unblock of $ip complete"
  ) &
}

# ---- Main ----

mkdir -p /var/log/ids /var/run/ids
touch "$BLOCK_LIST"

log_msg "Active Response started (AP=$AP_HOST, VPN=$VPN_SUBNET)"
log_msg "Monitoring $EVE_LOG for alerts (severity $MIN_SEVERITY-$MAX_SEVERITY)"

# Wait for eve.json to exist
while [[ ! -f "$EVE_LOG" ]]; do
  log_msg "Waiting for $EVE_LOG ..."
  sleep 5
done

tail -n 0 -F "$EVE_LOG" | \
  jq --unbuffered -r "
    select(.event_type == \"alert\") |
    select(.alert.severity >= $MIN_SEVERITY and .alert.severity <= $MAX_SEVERITY) |
    [.src_ip, (.alert.severity | tostring), .alert.signature] | @tsv
  " 2>/dev/null | \
while IFS=$'\t' read -r attacker_ip severity signature; do

  # Skip if whitelisted
  if is_whitelisted "$attacker_ip"; then
    continue
  fi

  # Skip if already blocked
  if is_already_blocked "$attacker_ip"; then
    continue
  fi

  log_msg "ALERT severity=$severity src=$attacker_ip sig=\"$signature\""

  # Dry-run: log only, don't block
  if [[ "$DRY_RUN" == "true" ]]; then
    if is_vpn_client "$attacker_ip"; then
      log_msg "DRY RUN: Would block $attacker_ip on ROUTER (VPN client)"
    else
      log_msg "DRY RUN: Would block $attacker_ip on AP ($AP_HOST)"
    fi
    continue
  fi

  # Track blocked IP
  echo "$attacker_ip" >> "$BLOCK_LIST"

  # Decide where to block
  if is_vpn_client "$attacker_ip"; then
    block_on_router "$attacker_ip"
    schedule_unblock "$attacker_ip" "router"
  else
    block_on_ap "$attacker_ip"
    schedule_unblock "$attacker_ip" "ap"
  fi

done
