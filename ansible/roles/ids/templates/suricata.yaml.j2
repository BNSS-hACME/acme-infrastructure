%YAML 1.1
---
{% set ids_mode_normalized = (ids_mode | default('ids') | lower) %}
{% set ids_home_nets_normalized = ids_home_nets | default([ids_home_net]) %}
vars:
  address-groups:
    HOME_NET: "[{{ ids_home_nets_normalized | join(',') }}]"
    EXTERNAL_NET: "!$HOME_NET"
    HTTP_SERVERS: "$HOME_NET"
    SMTP_SERVERS: "$HOME_NET"
    SQL_SERVERS: "$HOME_NET"
    DNS_SERVERS: "$HOME_NET"
    TELNET_SERVERS: "$HOME_NET"
    AIM_SERVERS: "$EXTERNAL_NET"
    DC_SERVERS: "$HOME_NET"
    DNP3_SERVER: "$HOME_NET"
    DNP3_CLIENT: "$HOME_NET"
    MODBUS_CLIENT: "$HOME_NET"
    MODBUS_SERVER: "$HOME_NET"
    ENIP_CLIENT: "$HOME_NET"
    ENIP_SERVER: "$HOME_NET"

  port-groups:
    HTTP_PORTS: "80,443,8080"
    SHELLCODE_PORTS: "!80"
    ORACLE_PORTS: 1521
    SSH_PORTS: 22
    DNP3_PORTS: 20000
    MODBUS_PORTS: 502
    FILE_DATA_PORTS: "[$HTTP_PORTS,110,143]"
    FTP_PORTS: 21
    GENEVE_PORTS: 6081
    VXLAN_PORTS: 4789
    TEREDO_PORTS: 3544

default-log-dir: {{ ids_log_dir }}
default-rule-path: {{ ids_rule_path }}
rule-files:
{% for rule_file in ids_rule_files %}
  - {{ rule_file }}
{% endfor %}
threshold-file: {{ ids_threshold_config_path }}

af-packet:
{% for ids_monitored_interface in ids_interfaces %}
  - interface: {{ ids_monitored_interface }}
    cluster-id: {{ 99 + loop.index0 }}
    cluster-type: cluster_flow
    defrag: yes
{% endfor %}

{% if ids_mode_normalized == 'ips' %}
nfq:
  mode: accept
  repeat-mark: 1
  repeat-mask: 1
  route-queue: 2
  batchcount: 20
  fail-open: yes
{% endif %}

stream:
  inline: {{ 'yes' if ids_mode_normalized == 'ips' else 'no' }}

app-layer:
  protocols:
{% for protocol, protocol_settings in ids_app_layer_protocols.items() %}
    {{ protocol }}:
{{ ({'enabled': true} | combine(protocol_settings, recursive=True)) | to_nice_yaml(indent=2, sort_keys=False) | indent(6, true) }}
{% endfor %}

outputs:
  - fast:
      enabled: yes
      filename: {{ ids_alert_log }}
  - eve-log:
      enabled: yes
      filetype: regular
      filemode: {{ ids_eve_log_filemode }}
      community-id: true
      filename: {{ ids_eve_log }}
      types:
{% for eve_type in ids_eve_types %}
{% if eve_type == 'http' %}
        - http:
            extended: yes
            dump-all-headers: both
{% elif eve_type == 'alert' %}
        - alert:
            payload: yes
            payload-buffer-size: 4kb
            payload-printable: yes
            packet: yes
            http-body: yes
{% else %}
        - {{ eve_type }}
{% endif %}
{% endfor %}


logging:
  default-log-level: notice
