<VirtualHost *:80>
    ServerAdmin webmaster@localhost
    DocumentRoot /var/www/html

    Alias /dvwa /var/www/html/dvwa

    <Directory /var/www/html/dvwa>
        AllowOverride None
        Require local
    </Directory>

    LogFormat "%h %l %u %t \"%r\" %>s %b \"%{Referer}i\" \"%{User-Agent}i\" \"%{UNIQUE_ID}e\"" combined_uid

    LogLevel {{ dvwa_apache_log_level | default('info') }}
    CustomLog /var/log/apache2/dvwa_access.log combined_uid
    ErrorLog /var/log/apache2/dvwa_error.log
</VirtualHost>
